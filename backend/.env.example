PORT=3001
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=你的数据库用户名
DB_PASSWORD=你的数据库密码
DB_NAME=tongda_silk
JWT_SECRET=替换为一个随机长字符串
JWT_EXPIRES_IN=7d
DEEPSEEK_API_KEY=你的DeepSeek_API_Key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_EMBED_MODEL=deepseek-embed
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ============================================
# 阿里云短信服务配置
# ============================================
# 开发环境：留空则使用模拟模式（验证码打印到控制台）
# 生产环境：必须配置真实的阿里云AccessKey
ALIBABACLOUD_ACCESS_KEY_ID=你的阿里云AccessKey ID
ALIBABACLOUD_ACCESS_KEY_SECRET=你的阿里云AccessKey Secret

# 短信签名（需要在阿里云短信控制台申请）
ALIBABACLOUD_SMS_SIGN_NAME=通达丝网

# 短信模板CODE（需要在阿里云短信控制台申请）
# 注册验证码模板
ALIBABACLOUD_SMS_TEMPLATE_REGISTER=SMS_XXXXXXXX
# 登录验证码模板
ALIBABACLOUD_SMS_TEMPLATE_LOGIN=SMS_XXXXXXXX
# 密码重置验证码模板
ALIBABACLOUD_SMS_TEMPLATE_RESET=SMS_XXXXXXXX

# 短信模板参数格式（通常不需要修改）
# 模板变量：{"code": "123456"}